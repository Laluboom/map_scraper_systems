# Copy this file to .env and fill in all values marked PLACEHOLDER

# --- Database (PH-001) ---
DATABASE_URL=postgresql://scraper:PLACEHOLDER_DB_PASSWORD@localhost:5432/scraper_db

# --- Redis (Celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- SendGrid (PH-002, PH-003) ---
SENDGRID_API_KEY=PLACEHOLDER_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=PLACEHOLDER_VERIFIED_SENDER@yourdomain.com
SENDGRID_FROM_NAME=John Doe

# --- AWS SES fallback (PH-004) ---
AWS_SES_ACCESS_KEY=PLACEHOLDER_AWS_ACCESS_KEY
AWS_SES_SECRET_KEY=PLACEHOLDER_AWS_SECRET_KEY
AWS_SES_REGION=us-east-1

# --- Email validation (PH-005, PH-006) ---
HUNTERIO_API_KEY=PLACEHOLDER_HUNTERIO_API_KEY
ZEROBOUNCE_API_KEY=PLACEHOLDER_ZEROBOUNCE_API_KEY

# --- Proxy (PH-007) ---
# Format depends on provider (BrightData, Oxylabs, etc.)
PROXY_URL=http://PLACEHOLDER_PROXY_USER:PLACEHOLDER_PROXY_PASS@PLACEHOLDER_PROXY_HOST:PORT

# --- Admin auth (PH-008) ---
SECRET_KEY=PLACEHOLDER_RANDOM_SECRET_KEY_MIN_32_CHARS

# --- App config ---
EMAIL_THROTTLE_PER_MINUTE=30
ENVIRONMENT=development
